# Copy to .env.local and fill in. .env.local is gitignored; this file is not, so
# never put a real value here.

# The only secret this project needs. It is read server-side, inside the API route
# — never prefixed with NEXT_PUBLIC_, which would inline it into the browser
# bundle and hand your credit card to anyone who opened devtools.
#
# Set a hard spend limit on this key in the OpenRouter dashboard. The app enforces
# its own daily cap, but a provider-enforced ceiling is the one a bug in our code
# cannot get past.
OPENROUTER_API_KEY=

# Optional. Override the model used for a role without touching lib/models.ts —
# this is how the eval harness sweeps a matrix of candidates. Unset means the
# defaults in lib/models.ts apply. An unknown id fails loudly rather than silently
# falling back, so a typo cannot quietly invalidate an eval run.
# OPENROUTER_MODEL_PLANNER=openai/gpt-5-nano
# OPENROUTER_MODEL_SPECIALIST=openai/gpt-5-mini
# OPENROUTER_MODEL_SYNTHESIZER=anthropic/claude-sonnet-5
